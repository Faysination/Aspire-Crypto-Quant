# /home/ec2-user/regime_bot/.env
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values.
# Never commit .env to git.
# ──────────────────────────────────────────────

# Binance API (Spot by default — set USE_FUTURES=true for futures)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading params
TRADING_SYMBOL=BTC/USDT
TIMEFRAME=15m
CAPITAL_USDT=200
RISK_PCT=0.02
USE_FUTURES=false

# Poll interval in seconds (match your timeframe roughly)
# 15m candle → poll every 60s is fine
POLL_SECONDS=60

# Telegram (reuse your existing Zoya bot token + chat ID)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# PAPER=true  → log signals only, no real orders
# PAPER=false → live execution
PAPER=true
